        {
            "name": "Flights",
            "item": [
                {
                    "name": "Get All Flights (Search)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/flights?origin=NYC&destination=LDN&date=2023-12-25&seatClass=Economy&maxPrice=1000",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "flights"
                            ],
                            "query": [
                                {
                                    "key": "origin",
                                    "value": "NYC",
                                    "description": "Filter by origin"
                                },
                                {
                                    "key": "destination",
                                    "value": "LDN",
                                    "description": "Filter by destination"
                                },
                                {
                                    "key": "date",
                                    "value": "2023-12-25",
                                    "description": "Filter by date (YYYY-MM-DD)"
                                },
                                {
                                    "key": "seatClass",
                                    "value": "Economy",
                                    "description": "Filter by seat class for price check"
                                },
                                {
                                    "key": "maxPrice",
                                    "value": "1000",
                                    "description": "Filter by max price"
                                }
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get Flight By ID",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/flights/:id",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "flights",
                                ":id"
                            ],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": "FLIGHT_ID_HERE"
                                }
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Create Flight (Admin)",
                    "request": {
                        "auth": {
                            "type": "bearer",
