                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"flightNumber\": \"SF101\",\n    \"airline\": \"StitchAir\",\n    \"origin\": \"NYC\",\n    \"destination\": \"LDN\",\n    \"departureDate\": \"2023-12-25\",\n    \"departureTime\": \"10:00\",\n    \"availableSeats\": 100,\n    \"basePrice\": 500,\n    \"isDirect\": true,\n    \"numberOfStops\": 0\n}",
